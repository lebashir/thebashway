{
  "name": "thebashway",
  "version": "0.3.2",
  "description": "Portable autonomous build loop: Build Mode + Fix Mode for any code repo, driven by Claude with evidence-backed gates.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./binding": "./src/binding.ts"
  },
  "bin": {
    "thebashway": "./src/cli.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun --bun x tsc --noEmit",
    "typecheck:all": "bun --bun x tsc --noEmit -p tsconfig.all.json",
    "thebashway": "bun run src/cli.ts",
    "verify": "bun run src/cli.ts verify"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
